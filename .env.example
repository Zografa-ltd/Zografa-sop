# .env.example
# Copy to .env.local and fill in values — NEVER commit .env.local

# Supabase (from: supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication — bcrypt hashes of your passwords (see README for how to generate)
# Generate with: node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PASSWORD', 12))"
EMPLOYEE_PASSWORD_HASH=
ADMIN_PASSWORD_HASH=

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI — Google Gemini API key (from: aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here
